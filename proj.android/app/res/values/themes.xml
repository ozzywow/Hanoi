<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ 시스템 스플래시(androidx.core:core-splashscreen).
         기본 흰 원 대신 브랜드 네이비 배경 + 투명 타워 로고를 노출한다.
         아이콘 배경색을 배경색과 동일하게 두어 원형 마스크가 보이지 않게 처리. -->
    <style name="Theme.App.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/splash_bg</item>
        <item name="postSplashScreenTheme">@style/Theme.App.Post</item>
    </style>

    <!-- 스플래시 종료 후 실제 게임 액티비티 테마(기존 풀스크린 유지).
         windowBackground을 네이비로 → GL 첫 프레임 전 흰 깜빡임 방지. -->
    <style name="Theme.App.Post" parent="@android:style/Theme.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@color/splash_bg</item>
    </style>
</resources>
